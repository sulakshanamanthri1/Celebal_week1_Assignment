      <div class="editor flex lazy-editor" style=""><pre class="lazy-virtualized" style="font-size: 14px; line-height: 19px;" tabindex="0"><pre class="lazy-gutter"></pre><pre class="monaco-colorized colab colab colab colab colab colab colab colab colab colab" data-lang="notebook-python"><span><span class="mtk1">P&nbsp;=&nbsp;np.array([[</span><span class="mtk12">2</span><span class="mtk1">,&nbsp;</span><span class="mtk12">1</span><span class="mtk1">],&nbsp;[</span><span class="mtk12">0</span><span class="mtk1">,&nbsp;</span><span class="mtk12">3</span><span class="mtk1">]])</span></span><br><span><span class="mtk1">Q&nbsp;=&nbsp;np.array([[</span><span class="mtk12">1</span><span class="mtk1">,&nbsp;</span><span class="mtk12">4</span><span class="mtk1">],&nbsp;[</span><span class="mtk12">2</span><span class="mtk1">,&nbsp;</span><span class="mtk12">0</span><span class="mtk1">]])</span></span><br><span><span></span></span><br><span><span class="mtk1">PplusQ&nbsp;=&nbsp;P+Q</span></span><br><span><span class="mtk1">scalar3P=&nbsp;</span><span class="mtk12">3</span><span class="mtk1">*P</span></span><br><span><span class="mtk1">PQ=P@Q</span></span><br><span><span class="mtk1">QP&nbsp;=&nbsp;Q@P</span></span><br><span><span></span></span><br><span><span></span></span><br><span><span class="mtk15">print</span><span class="mtk1">(</span><span class="mtk6">f</span><span class="mtk21">"P&nbsp;+&nbsp;Q&nbsp;=\n</span><span class="mtk1">{PplusQ}</span><span class="mtk21">"</span><span class="mtk1">)</span></span><br><span><span class="mtk15">print</span><span class="mtk1">(</span><span class="mtk6">f</span><span class="mtk21">"3*P&nbsp;=\n</span><span class="mtk1">{scalar3P}</span><span class="mtk21">"</span><span class="mtk1">)</span></span><br><span><span class="mtk15">print</span><span class="mtk1">(</span><span class="mtk6">f</span><span class="mtk21">"P&nbsp;@&nbsp;Q&nbsp;=\n</span><span class="mtk1">{PQ}</span><span class="mtk21">"</span><span class="mtk1">)</span></span><br><span><span class="mtk15">print</span><span class="mtk1">(</span><span class="mtk6">f</span><span class="mtk21">"Q&nbsp;@&nbsp;P&nbsp;=\n</span><span class="mtk1">{QP}</span><span class="mtk21">"</span><span class="mtk1">)</span></span><br><span><span class="mtk15">print</span><span class="mtk1">(</span><span class="mtk6">f</span><span class="mtk21">"PQ&nbsp;==&nbsp;QP?&nbsp;</span><span class="mtk1">{np.array_equal(PQ,&nbsp;QP)}</span><span class="mtk21">"</span><span class="mtk1">)</span></span><br><span><span></span></span><br><span><span class="mtk19">assert</span><span class="mtk1">&nbsp;</span><span class="mtk6">not</span><span class="mtk1">&nbsp;np.array_equal(PQ,&nbsp;QP),&nbsp;</span><span class="mtk21">"They&nbsp;should&nbsp;differ!"</span></span><br><span><span class="mtk15">print</span><span class="mtk1">(</span><span class="mtk21">"4.2&nbsp;passed&nbsp;✓"</span><span class="mtk1">)</span></span><br></pre><colab-read-only-cell-placeholder style="display: none;"><template shadowrootmode="open"><!----><div><!--?lit$221561496$-->Start coding or <span role="button" class="link" tabindex="0">generate</span> with AI.</div></template></colab-read-only-cell-placeholder></pre></div><colab-form class="formview vertical layout flex"><div class="widget-area"></div></colab-form></div>
