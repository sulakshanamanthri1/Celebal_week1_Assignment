      <div class="editor flex lazy-editor" style=""><pre class="lazy-virtualized" style="font-size: 14px; line-height: 19px;" tabindex="0"><pre class="lazy-gutter"></pre><pre class="monaco-colorized colab colab colab colab colab colab colab colab colab colab colab" data-lang="notebook-python"><span><span class="mtk1">y_true&nbsp;=&nbsp;np.array([</span><span class="mtk12">3.0</span><span class="mtk1">,&nbsp;</span><span class="mtk12">5.0</span><span class="mtk1">,&nbsp;</span><span class="mtk12">2.5</span><span class="mtk1">,&nbsp;</span><span class="mtk12">7.0</span><span class="mtk1">,&nbsp;</span><span class="mtk12">4.5</span><span class="mtk1">,&nbsp;</span><span class="mtk12">6.0</span><span class="mtk1">,&nbsp;</span><span class="mtk12">1.5</span><span class="mtk1">,&nbsp;</span><span class="mtk12">8.0</span><span class="mtk1">])</span></span><br><span><span class="mtk1">y_pred&nbsp;=&nbsp;np.array([</span><span class="mtk12">2.8</span><span class="mtk1">,&nbsp;</span><span class="mtk12">5.2</span><span class="mtk1">,&nbsp;</span><span class="mtk12">2.1</span><span class="mtk1">,&nbsp;</span><span class="mtk12">7.5</span><span class="mtk1">,&nbsp;</span><span class="mtk12">4.0</span><span class="mtk1">,&nbsp;</span><span class="mtk12">6.3</span><span class="mtk1">,&nbsp;</span><span class="mtk12">2.0</span><span class="mtk1">,&nbsp;</span><span class="mtk12">7.8</span><span class="mtk1">])</span></span><br><span><span class="mtk1">n,&nbsp;p&nbsp;=&nbsp;</span><span class="mtk15">len</span><span class="mtk1">(y_true),&nbsp;</span><span class="mtk12">2</span></span><br><span><span></span></span><br><span><span class="mtk1">mae&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;=&nbsp;np.mean(np.</span><span class="mtk15">abs</span><span class="mtk1">(y_true&nbsp;-&nbsp;y_pred))&nbsp;</span></span><br><span><span class="mtk1">mse&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;=&nbsp;np.mean((y_true&nbsp;-&nbsp;y_pred)&nbsp;**&nbsp;</span><span class="mtk12">2</span><span class="mtk1">)&nbsp;</span></span><br><span><span class="mtk1">rmse&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;=&nbsp;np.sqrt(mse)&nbsp;</span></span><br><span><span class="mtk1">r2&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;=&nbsp;</span><span class="mtk12">1</span><span class="mtk1">-(&nbsp;np.</span><span class="mtk15">sum</span><span class="mtk1">((y_true&nbsp;-&nbsp;y_pred)&nbsp;**&nbsp;</span><span class="mtk12">2</span><span class="mtk1">)/np.</span><span class="mtk15">sum</span><span class="mtk1">((y_true&nbsp;-&nbsp;np.mean(y_true))&nbsp;**&nbsp;</span><span class="mtk12">2</span><span class="mtk1">))&nbsp;</span></span><br><span><span class="mtk1">adj_r2&nbsp;&nbsp;&nbsp;=&nbsp;</span><span class="mtk12">1</span><span class="mtk1">&nbsp;-&nbsp;(</span><span class="mtk12">1</span><span class="mtk1">&nbsp;-&nbsp;r2)&nbsp;*&nbsp;(n&nbsp;-&nbsp;</span><span class="mtk12">1</span><span class="mtk1">)&nbsp;/&nbsp;(n&nbsp;-&nbsp;p&nbsp;-&nbsp;</span><span class="mtk12">1</span><span class="mtk1">)&nbsp;&nbsp;&nbsp;</span><span class="mtk8">#&nbsp;YOUR&nbsp;CODE&nbsp;HERE&nbsp;&nbsp;formula:&nbsp;1&nbsp;-&nbsp;(1-r2)*(n-1)/(n-p-1</span><span class="mtk8">)</span></span><br><span><span></span></span><br><span><span class="mtk15">print</span><span class="mtk1">(</span><span class="mtk6">f</span><span class="mtk21">"MAE:&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk1">{mae</span><span class="mtk12">:.4f</span><span class="mtk1">}</span><span class="mtk21">"</span><span class="mtk1">)</span></span><br><span><span class="mtk15">print</span><span class="mtk1">(</span><span class="mtk6">f</span><span class="mtk21">"MSE:&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk1">{mse</span><span class="mtk12">:.4f</span><span class="mtk1">}</span><span class="mtk21">"</span><span class="mtk1">)</span></span><br><span><span class="mtk15">print</span><span class="mtk1">(</span><span class="mtk6">f</span><span class="mtk21">"RMSE:&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk1">{rmse</span><span class="mtk12">:.4f</span><span class="mtk1">}</span><span class="mtk21">"</span><span class="mtk1">)</span></span><br><span><span class="mtk15">print</span><span class="mtk1">(</span><span class="mtk6">f</span><span class="mtk21">"R²:&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk1">{r2</span><span class="mtk12">:.4f</span><span class="mtk1">}</span><span class="mtk21">"</span><span class="mtk1">)</span></span><br><span><span class="mtk15">print</span><span class="mtk1">(</span><span class="mtk6">f</span><span class="mtk21">"Adj.&nbsp;R²:&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk1">{adj_r2</span><span class="mtk12">:.4f</span><span class="mtk1">}</span><span class="mtk21">"</span><span class="mtk1">)</span></span><br></pre><colab-read-only-cell-placeholder style="display: none;"><template shadowrootmode="open"><!----><div><!--?lit$221561496$-->Start coding or <span role="button" class="link" tabindex="0">generate</span> with AI.</div></template></colab-read-only-cell-placeholder></pre></div><colab-form class="formview vertical layout flex"><div class="widget-area"></div></colab-form></div>
