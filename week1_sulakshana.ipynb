      <div class="editor flex lazy-editor" style=""><pre class="lazy-virtualized" style="font-size: 14px; line-height: 19px;" tabindex="0"><pre class="lazy-gutter"></pre><pre class="monaco-colorized colab colab colab colab colab colab colab colab colab colab colab colab colab colab colab" data-lang="notebook-python"><span><span class="mtk1">fig,&nbsp;axes&nbsp;=&nbsp;plt.subplots(</span><span class="mtk12">1</span><span class="mtk1">,&nbsp;</span><span class="mtk12">3</span><span class="mtk1">,&nbsp;figsize=(</span><span class="mtk12">15</span><span class="mtk1">,&nbsp;</span><span class="mtk12">4</span><span class="mtk1">))</span></span><br><span><span class="mtk19">from</span><span class="mtk1">&nbsp;scipy.stats&nbsp;</span><span class="mtk19">import</span><span class="mtk1">&nbsp;norm,&nbsp;binom,&nbsp;poisson</span></span><br><span><span class="mtk8">#&nbsp;──&nbsp;Normal&nbsp;</span><span class="mtk8">──────────────────────────────────────────────────────────────────</span></span><br><span><span class="mtk1">x&nbsp;=&nbsp;np.linspace(</span><span class="mtk12">-4</span><span class="mtk1">,&nbsp;</span><span class="mtk12">6</span><span class="mtk1">,&nbsp;</span><span class="mtk12">300</span><span class="mtk1">)</span></span><br><span><span class="mtk1">axes[</span><span class="mtk12">0</span><span class="mtk1">].plot(x,&nbsp;norm.pdf(x,&nbsp;</span><span class="mtk12">0</span><span class="mtk1">,&nbsp;</span><span class="mtk12">1</span><span class="mtk1">),&nbsp;label=</span><span class="mtk21">"N(0,1)"</span><span class="mtk1">)</span></span><br><span><span class="mtk1">axes[</span><span class="mtk12">0</span><span class="mtk1">].plot(x,&nbsp;norm.pdf(x,&nbsp;</span><span class="mtk12">2</span><span class="mtk1">,&nbsp;</span><span class="mtk12">1</span><span class="mtk1">),&nbsp;label=</span><span class="mtk21">"N(2,1)"</span><span class="mtk1">)</span></span><br><span><span></span></span><br><span><span class="mtk8">#&nbsp;ML&nbsp;use&nbsp;case:&nbsp;&nbsp;Used&nbsp;in&nbsp;Gaussian&nbsp;Naive&nbsp;Bayes&nbsp;and&nbsp;a</span><span class="mtk8">ssumes&nbsp;features&nbsp;follow&nbsp;a&nbsp;normal&nbsp;distribution</span></span><br><span><span class="mtk1">axes[</span><span class="mtk12">0</span><span class="mtk1">].set_title(</span><span class="mtk21">'Normal&nbsp;Distribution'</span><span class="mtk1">)</span></span><br><span><span class="mtk1">axes[</span><span class="mtk12">0</span><span class="mtk1">].legend()</span></span><br><span><span></span></span><br><span><span class="mtk8">#&nbsp;──&nbsp;Binomial&nbsp;</span><span class="mtk8">────────────────────────────────────────────────────────────────</span></span><br><span><span class="mtk1">k&nbsp;=&nbsp;np.arange(</span><span class="mtk12">0</span><span class="mtk1">,&nbsp;</span><span class="mtk12">21</span><span class="mtk1">)</span></span><br><span><span class="mtk1">axes[</span><span class="mtk12">1</span><span class="mtk1">].stem(k,&nbsp;binom.pmf(k,&nbsp;</span><span class="mtk12">20</span><span class="mtk1">,&nbsp;</span><span class="mtk12">0.5</span><span class="mtk1">),&nbsp;linefmt=</span><span class="mtk21">'b-'</span><span class="mtk1">,&nbsp;markerfmt=</span><span class="mtk21">'bo'</span><span class="mtk1">,&nbsp;basefmt=</span><span class="mtk21">"&nbsp;"</span><span class="mtk1">,&nbsp;label=</span><span class="mtk21">"p=0.5"</span><span class="mtk1">)</span></span><br><span><span class="mtk1">axes[</span><span class="mtk12">1</span><span class="mtk1">].stem(k,&nbsp;binom.pmf(k,&nbsp;</span><span class="mtk12">20</span><span class="mtk1">,&nbsp;</span><span class="mtk12">0.7</span><span class="mtk1">),&nbsp;linefmt=</span><span class="mtk21">'r-'</span><span class="mtk1">,&nbsp;markerfmt=</span><span class="mtk21">'ro'</span><span class="mtk1">,&nbsp;basefmt=</span><span class="mtk21">"&nbsp;"</span><span class="mtk1">,&nbsp;label=</span><span class="mtk21">"p=0.7"</span><span class="mtk1">)</span></span><br><span><span></span></span><br><span><span class="mtk8">#&nbsp;YOUR&nbsp;CODE&nbsp;HERE&nbsp;—&nbsp;plot&nbsp;PMFs&nbsp;for&nbsp;p=0.5&nbsp;and&nbsp;p=0.7&nbsp;</span><span class="mtk8">on&nbsp;axes[1]</span></span><br><span><span class="mtk8">#&nbsp;ML&nbsp;use&nbsp;case:&nbsp;Used&nbsp;to&nbsp;model&nbsp;binary&nbsp;outcomes&nbsp;like&nbsp;</span><span class="mtk8">click/no-click,&nbsp;pass/fail&nbsp;in&nbsp;A/B&nbsp;testing,&nbsp;or&nbsp;conve</span><span class="mtk8">rsion&nbsp;counts.</span></span><br><span><span class="mtk1">axes[</span><span class="mtk12">1</span><span class="mtk1">].set_title(</span><span class="mtk21">'Binomial&nbsp;Distribution'</span><span class="mtk1">)</span></span><br><span><span></span></span><br><span><span class="mtk8">#&nbsp;──&nbsp;Poisson&nbsp;</span><span class="mtk8">─────────────────────────────────────────────────────────────────</span></span><br><span><span class="mtk1">k2&nbsp;=&nbsp;np.arange(</span><span class="mtk12">0</span><span class="mtk1">,&nbsp;</span><span class="mtk12">16</span><span class="mtk1">)</span></span><br><span><span class="mtk8">#&nbsp;YOUR&nbsp;CODE&nbsp;HERE&nbsp;—&nbsp;plot&nbsp;PMF&nbsp;(λ=3)&nbsp;on&nbsp;axes[2]</span></span><br><span><span></span></span><br><span><span class="mtk1">axes[</span><span class="mtk12">2</span><span class="mtk1">].stem(k2,&nbsp;poisson.pmf(k2,&nbsp;mu=</span><span class="mtk12">3</span><span class="mtk1">),&nbsp;basefmt=</span><span class="mtk21">"&nbsp;"</span><span class="mtk1">)</span></span><br><span><span class="mtk1">axes[</span><span class="mtk12">2</span><span class="mtk1">].set_title(</span><span class="mtk21">'Poisson&nbsp;Distribution'</span><span class="mtk1">)</span></span><br><span><span></span></span><br><span><span class="mtk8">#&nbsp;ML&nbsp;use&nbsp;case:&nbsp;Used&nbsp;to&nbsp;model&nbsp;event&nbsp;arrival&nbsp;counts&nbsp;</span><span class="mtk8">like&nbsp;number&nbsp;of&nbsp;customers&nbsp;per&nbsp;minute&nbsp;or&nbsp;requests&nbsp;pe</span><span class="mtk8">r&nbsp;server&nbsp;interval.</span></span><br><span><span class="mtk1">axes[</span><span class="mtk12">2</span><span class="mtk1">].set_title(</span><span class="mtk21">'Poisson&nbsp;Distribution'</span><span class="mtk1">)</span></span><br><span><span></span></span><br><span><span class="mtk1">plt.tight_layout();&nbsp;plt.show()</span></span><br></pre><colab-read-only-cell-placeholder style="display: none;"><template shadowrootmode="open"><!----><div><!--?lit$221561496$-->Start coding or <span role="button" class="link" tabindex="0">generate</span> with AI.</div></template></colab-read-only-cell-placeholder></pre></div><colab-form class="formview vertical layout flex"><div class="widget-area"></div></colab-form></div>
