span class="mtk1">{median_s</span><span class="mtk12">:.0f</span><span class="mtk1">}</span><span class="mtk21">"</span><span class="mtk1">)</span></span><br><span><span class="mtk15">print</span><span class="mtk1">(</span><span class="mtk6">f</span><span class="mtk21">"Std:&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk1">{std_s</span><span class="mtk12">:.0f</span><span class="mtk1">}</span><span class="mtk21">"</span><span class="mtk1">)</span></span><br><span><span class="mtk15">print</span><span class="mtk1">(</span><span class="mtk6">f</span><span class="mtk21">"Range:&nbsp;&nbsp;</span><span class="mtk1">{min_s</span><span class="mtk12">:.0f</span><span class="mtk1">}</span><span class="mtk21">&nbsp;–&nbsp;</span><span class="mtk1">{max_s</span><span class="mtk12">:.0f</span><span class="mtk1">}</span><span class="mtk21">"</span><span class="mtk1">)</span></span><br><span><span class="mtk15">print</span><span class="mtk1">(</span><span class="mtk6">f</span><span class="mtk21">"IQR:&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk1">{iqr_s</span><span class="mtk12">:.0f</span><span class="mtk1">}</span><span class="mtk21">"</span><span class="mtk1">)</span></span><br><span><span></span></span><br><span><span class="mtk8">#&nbsp;Histogram&nbsp;+&nbsp;KDE</span></span><br><span><span class="mtk1">fig,&nbsp;ax&nbsp;=&nbsp;plt.subplots()</span></span><br><span><span class="mtk8">#&nbsp;YOUR&nbsp;CODE&nbsp;HERE</span></span><br><span><span class="mtk1">sns.histplot(df[</span><span class="mtk21">'salary'</span><span class="mtk1">],&nbsp;kde=</span><span class="mtk6">True</span><span class="mtk1">,&nbsp;bins=</span><span class="mtk12">20</span><span class="mtk1">,&nbsp;ax=ax)</span></span><br><span><span></span></span><br><span><span class="mtk1">ax.set_xlabel(</span><span class="mtk21">'Salary'</span><span class="mtk1">);&nbsp;ax.set_title(</span><span class="mtk21">'Salary&nbsp;Distribution'</span><span class="mtk1">)</span></span><br><span><span class="mtk1">plt.tig