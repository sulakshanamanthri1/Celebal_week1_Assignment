      <div class="editor flex lazy-editor" style=""><pre class="lazy-virtualized" style="font-size: 14px; line-height: 19px;" tabindex="0"><pre class="lazy-gutter"></pre><pre class="monaco-colorized colab colab colab colab colab colab colab colab colab colab colab colab colab colab colab colab colab colab colab colab" data-lang="notebook-python"><span><span class="mtk1">p_spam&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;=&nbsp;</span><span class="mtk12">0.30</span></span><br><span><span class="mtk1">p_free_given_spam&nbsp;=&nbsp;</span><span class="mtk12">0.80</span></span><br><span><span class="mtk1">p_free_given_ham&nbsp;&nbsp;=&nbsp;</span><span class="mtk12">0.05</span></span><br><span><span class="mtk1">p_ham&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;=&nbsp;</span><span class="mtk12">1</span><span class="mtk1">&nbsp;-&nbsp;p_spam</span></span><br><span><span></span></span><br><span><span class="mtk8">#&nbsp;P(free)&nbsp;—&nbsp;law&nbsp;of&nbsp;total&nbsp;probability</span></span><br><span><span class="mtk1">p_free&nbsp;=&nbsp;(p_free_given_spam&nbsp;*&nbsp;p_spam)&nbsp;+&nbsp;(p_free_gi</span><span class="mtk1">ven_ham&nbsp;*&nbsp;p_ham)</span></span><br><span><span></span></span><br><span><span class="mtk8">#&nbsp;Bayes</span></span><br><span><span class="mtk1">p_spam_given_free&nbsp;=&nbsp;(p_free_given_spam&nbsp;*&nbsp;p_spam)&nbsp;/</span><span class="mtk1">&nbsp;p_free</span></span><br><span><span class="mtk15">print</span><span class="mtk1">(</span><span class="mtk6">f</span><span class="mtk21">"P('free'):&nbsp;</span><span class="mtk1">{p_free</span><span class="mtk12">:.4f</span><span class="mtk1">}</span><span class="mtk21">"</span><span class="mtk1">)</span></span><br><span><span class="mtk15">print</span><span class="mtk1">(</span><span class="mtk6">f</span><span class="mtk21">"P(Spam&nbsp;</span><span class="mtk1">|</span><span class="mtk21">&nbsp;'free'):&nbsp;</span><span class="mtk1">{p_spam_given_free</span><span class="mtk12">:.4f</span><span class="mtk1">}</span><span class="mtk21">"</span><span class="mtk1">)</span></span><br><span><span></span></span><br><span><span class="mtk6">def</span><span class="mtk1">&nbsp;</span><span class="mtk15">naive_bayes_predict</span><span class="mtk1">(</span><span class="mtk16">prior_spam</span><span class="mtk1">,&nbsp;</span><span class="mtk16">p_word_given_spam</span><span class="mtk1">,&nbsp;</span><span class="mtk16">p_word_given_ham</span><span class="mtk1">):</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;prior_ham&nbsp;=&nbsp;</span><span class="mtk12">1</span><span class="mtk1">&nbsp;-&nbsp;prior_spam</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;evidence&nbsp;=&nbsp;(p_word_given_spam&nbsp;*&nbsp;prior_spam)&nbsp;+&nbsp;</span><span class="mtk1">(p_word_given_ham&nbsp;*&nbsp;prior_ham)</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;posterior&nbsp;=&nbsp;(p_word_given_spam&nbsp;*&nbsp;prior_spam)&nbsp;/</span><span class="mtk1">&nbsp;evidence</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk19">return</span><span class="mtk1">&nbsp;posterior</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span></span><br><span><span></span></span><br><span><span class="mtk1">pred&nbsp;=&nbsp;naive_bayes_predict(</span><span class="mtk12">0.30</span><span class="mtk1">,&nbsp;</span><span class="mtk12">0.80</span><span class="mtk1">,&nbsp;</span><span class="mtk12">0.05</span><span class="mtk1">)</span></span><br><span><span class="mtk19">assert</span><span class="mtk1">&nbsp;</span><span class="mtk15">abs</span><span class="mtk1">(pred&nbsp;-&nbsp;p_spam_given_free)&nbsp;&lt;&nbsp;</span><span class="mtk12">1e-9</span></span><br><span><span class="mtk15">print</span><span class="mtk1">(</span><span class="mtk6">f</span><span class="mtk21">"naive_bayes_predict:&nbsp;</span><span class="mtk1">{pred</span><span class="mtk12">:.4f</span><span class="mtk1">}</span><span class="mtk21">"</span><span class="mtk1">)</span></span><br><span><span class="mtk15">print</span><span class="mtk1">(</span><span class="mtk21">"6.3&nbsp;passed&nbsp;✓"</span><span class="mtk1">)</span></span><br></pre><colab-read-only-cell-placeholder style="display: none;"><template shadowrootmode="open"><!----><div><!--?lit$221561496$-->Start coding or <span role="button" class="link" tabindex="0">generate</span> with AI.</div></template></colab-read-only-cell-placeholder></pre></div><colab-form class="formview vertical layout flex"><div class="widget-area"></div></colab-form></div>
