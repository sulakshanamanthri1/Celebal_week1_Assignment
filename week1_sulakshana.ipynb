      <div class="editor flex lazy-editor" style=""><pre class="lazy-virtualized" style="font-size: 14px; line-height: 19px;" tabindex="0"><pre class="lazy-gutter"></pre><pre class="monaco-colorized colab colab colab colab colab colab colab colab colab colab colab" data-lang="notebook-python"><span><span class="mtk1">eng_salaries&nbsp;=&nbsp;df_filled[df_filled[</span><span class="mtk21">'department'</span><span class="mtk1">]&nbsp;==&nbsp;</span><span class="mtk21">'Engineering'</span><span class="mtk1">][</span><span class="mtk21">'salary'</span><span class="mtk1">]</span></span><br><span><span class="mtk1">overall_mean&nbsp;=&nbsp;df_filled[</span><span class="mtk21">'salary'</span><span class="mtk1">].mean()</span></span><br><span><span></span></span><br><span><span class="mtk8">#&nbsp;One-sample&nbsp;t-test</span></span><br><span><span class="mtk1">t_stat,&nbsp;p_value&nbsp;=&nbsp;stats.ttest_1samp(eng_salaries,&nbsp;</span><span class="mtk1">overall_mean)&nbsp;&nbsp;</span><span class="mtk8">#&nbsp;YOUR&nbsp;CODE&nbsp;HERE&nbsp;—&nbsp;use&nbsp;stats.ttest_1samp</span></span><br><span><span></span></span><br><span><span class="mtk15">print</span><span class="mtk1">(</span><span class="mtk6">f</span><span class="mtk21">"Overall&nbsp;mean&nbsp;salary:&nbsp;</span><span class="mtk1">{overall_mean</span><span class="mtk12">:.0f</span><span class="mtk1">}</span><span class="mtk21">"</span><span class="mtk1">)</span></span><br><span><span class="mtk15">print</span><span class="mtk1">(</span><span class="mtk6">f</span><span class="mtk21">"Engineering&nbsp;mean&nbsp;salary:&nbsp;</span><span class="mtk1">{eng_salaries.mean()</span><span class="mtk12">:.0f</span><span class="mtk1">}</span><span class="mtk21">"</span><span class="mtk1">)</span></span><br><span><span class="mtk15">print</span><span class="mtk1">(</span><span class="mtk6">f</span><span class="mtk21">"t-statistic:&nbsp;</span><span class="mtk1">{t_stat</span><span class="mtk12">:.4f</span><span class="mtk1">}</span><span class="mtk21">"</span><span class="mtk1">)</span></span><br><span><span class="mtk15">print</span><span class="mtk1">(</span><span class="mtk6">f</span><span class="mtk21">"p-value:&nbsp;</span><span class="mtk1">{p_value</span><span class="mtk12">:.4f</span><span class="mtk1">}</span><span class="mtk21">"</span><span class="mtk1">)</span></span><br><span><span class="mtk15">print</span><span class="mtk1">(</span><span class="mtk6">f</span><span class="mtk21">"Reject&nbsp;H0&nbsp;at&nbsp;α=0.05?&nbsp;</span><span class="mtk1">{p_value&nbsp;&lt;&nbsp;</span><span class="mtk12">0.05</span><span class="mtk1">}</span><span class="mtk21">"</span><span class="mtk1">)</span></span><br><span><span></span></span><br><span><span class="mtk8">#&nbsp;Pearson&nbsp;correlation</span></span><br><span><span class="mtk1">r,&nbsp;r_pval&nbsp;=&nbsp;stats.pearsonr(df_filled[</span><span class="mtk21">'salary'</span><span class="mtk1">],&nbsp;df_filled[</span><span class="mtk21">'years_exp'</span><span class="mtk1">])&nbsp;</span><span class="mtk8">#&nbsp;YOUR&nbsp;CODE&nbsp;HERE&nbsp;—&nbsp;use&nbsp;stats.pearsonr</span></span><br><span><span class="mtk15">print</span><span class="mtk1">(</span><span class="mtk6">f</span><span class="mtk21">"\nPearson&nbsp;r&nbsp;(salary&nbsp;vs&nbsp;years_exp):&nbsp;</span><span class="mtk1">{r</span><span class="mtk12">:.4f</span><span class="mtk1">}</span><span class="mtk21">,&nbsp;p=</span><span class="mtk1">{r_pval</span><span class="mtk12">:.4f</span><span class="mtk1">}</span><span class="mtk21">"</span><span class="mtk1">)</span></span><br></pre><colab-read-only-cell-placeholder style="display: none;"><template shadowrootmode="open"><!----><div><!--?lit$221561496$-->Start coding or <span role="button" class="link" tabindex="0">generate</span> with AI.</div></template></colab-read-only-cell-placeholder></pre></div><colab-form class="formview vertical layout flex"><div class="widget-area"></div></colab-form></div>
